name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:

      input_artifact:
        description: "Input Artifact"
        type: str

      output_artifact:
        description: "Output Artifact"
        type: str

      output_type:
        description: "Output Type"
        type: str

      output_description:
        description: "Output Description"
        type: str

      min_price:
        description: "Min Price"
        required: true
        type: float

      max_price:
        description: "Max Price"
        required: true
        type: float
  

    command: >-
        python run.py  --min_price {min_price} --max_price {max_price} --input_artifact {input_artifact} --output_artifact {output_artifact} --output_type {output_type} --output_description {output_description}